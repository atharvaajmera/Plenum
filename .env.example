# Copy this file to `.env` at the repo root (docker compose loads it automatically).
# Never commit the real `.env` -- it's already covered by .gitignore.

# Generate with: openssl rand -hex 32
TURN_SHARED_SECRET=

# DNS name that already points at this host's public IP (A record).
# Caddy uses it to request a Let's Encrypt cert and to route by Host header.
CADDY_DOMAIN=

# coturn addressing (see docker-compose.yml). On EC2: private IP from
# `hostname -I` (first entry), public IP is the instance's Elastic IP.
# Update both after any instance move/region migration.
TURN_PRIVATE_IP=
TURN_PUBLIC_IP=
